PORT=8787

# ---------------------------------------------------------------------------
# DATABASE_URL on Render + Supabase (IMPORTANT)
# ---------------------------------------------------------------------------
# If you see: "Can't reach database server at db.*.supabase.co:5432"
# your host (e.g. Render) uses IPv4-only outbound traffic. Supabase's *direct*
# URL (db.<project>.supabase.co port 5432) is often unreachable from there.
#
# Fix: Supabase Dashboard → your project → Connect → "Transaction pooler"
# (or Session mode pooler). Copy the Postgres URI. It looks like:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Paste that ENTIRE string as DATABASE_URL on Render (Environment). Redeploy.
# Also ensure the Supabase project is not paused (free tier).
# ---------------------------------------------------------------------------

# Local Postgres (development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/puresignal
#
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Stripe: use sk_test_... for sandbox (selects STRIPE_PRICE_*_TEST vars automatically).
# Or set STRIPE_SANDBOX=true to force test prices even if you use a nonstandard secret.
# STRIPE_SANDBOX=false forces live price env vars with sk_test (rare).
STRIPE_SECRET_KEY=sk_test_replace_me
# Live Dashboard endpoint signing secret (sk_live webhooks)
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Test mode / CLI listen (Stripe CLI prints whsec_…); used when sk_test_ or STRIPE_SANDBOX=true
STRIPE_WEBHOOK_SECRET_TEST=whsec_replace_me_test

# Live-mode price IDs (sk_live_…)
STRIPE_PRICE_EXT_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_EXT_PRO_YEARLY=price_replace_me
STRIPE_PRICE_DESKTOP_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_DESKTOP_PRO_YEARLY=price_replace_me
STRIPE_PRICE_BUNDLE_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_BUNDLE_PRO_YEARLY=price_replace_me

# Sandbox / test-mode price IDs (sk_test_… — same account as Dashboard test mode)
STRIPE_PRICE_EXT_PRO_MONTHLY_TEST=price_1TRk4kD8fSWBCq6G4JgMRxRF
STRIPE_PRICE_EXT_PRO_YEARLY_TEST=price_1TRk57D8fSWBCq6GJ7k1M46N
STRIPE_PRICE_DESKTOP_PRO_MONTHLY_TEST=price_1TRk5iD8fSWBCq6GnzMzGkVq
STRIPE_PRICE_DESKTOP_PRO_YEARLY_TEST=price_1TRk5iD8fSWBCq6GkTmhH6EY
STRIPE_PRICE_BUNDLE_PRO_MONTHLY_TEST=price_1TRk4SD8fSWBCq6GE0hqWo9G
STRIPE_PRICE_BUNDLE_PRO_YEARLY_TEST=price_1TRk4SD8fSWBCq6GuQwA3RwI

# Legacy yearly alias (optional, live or test)
# STRIPE_PRICE_EXT_PRO_ANNUAL=price_replace_me

BLOCKLIST_MANIFEST_SIGNATURE=replace_with_base64_signature
