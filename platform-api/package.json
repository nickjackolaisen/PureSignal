{
  "name": "puresignal-platform-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && prisma migrate deploy && tsc -p tsconfig.json",
    "build:ci": "prisma generate && tsc -p tsconfig.json",
