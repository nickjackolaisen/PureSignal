generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  extension
  desktop
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  authProvider String
  mfaEnabled   Boolean  @default(false)
  consentFlags Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  devices       Device[]
  subscriptions Subscription[]
  alertEvents   AlertEvent[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String
  stripeCustomerId String    @unique
  status           String
  planCode         String
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id              String     @id @default(cuid())
  userId          String
  type            DeviceType
  name            String
  deviceTokenHash String
  appVersion      String
  lastSeenAt      DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]
}

model Entitlement {
  id        String   @id @default(cuid())
  scopeType String
  scopeId   String
  planCode  String
  flags     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlocklistRelease {
  id               String   @id @default(cuid())
  version          String   @unique
  changelog        String
  artifactUrls     Json
  sha256           String
  signature        String
  minClientVersion String   @default("1.0.0")
  deprecated       Boolean  @default(false)
  publishedAt      DateTime
}

model AlertEvent {
  id              String   @id @default(cuid())
  userId          String
  deviceId        String
  type            String
  payloadRedacted Json
  deliveryStatus  String
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model WhitelistSync {
  id        String   @id @default(cuid())
  userId    String
  domain    String
  reason    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid())
  email     String
  domain    String
  reason    String
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  email     String
  message   String
  createdAt DateTime @default(now())
}
