{
  "manifest_version": 3,
  "name": "ClarityGuard – Block Porn & Build Focus",
  "version": "1.0.0",
  "description": "50,000+ sites blocked. Zero excuses.",
  "icons": { "128": "icon128.png" },
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "options_page": "options.html",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "webNavigation", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "blocklist_1", "enabled": true, "path": "rules/blocklist_1.json" },
      { "id": "blocklist_2", "enabled": true, "path": "rules/blocklist_2.json" }
      // add more if you split your 50k list
    ]
  }
}
